# ── Admin authentication: Google sign-in only (Auth.js) ──
#
# The admin area (/admin) is gated solely by Google OAuth, restricted to the
# emails listed in ADMIN_ALLOWED_EMAILS below. There is no password login.

# Auth.js session secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth 2.0 Web client credentials (Google Cloud Console →
# APIs & Services → Credentials). Authorized redirect URI:
#   <origin>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated allowlist of Google emails permitted into /admin.
ADMIN_ALLOWED_EMAILS=

# ── Vercel Edge Config (tool visibility storage) ──

# Connection string for the Edge Config store.
# Auto-injected by Vercel when an Edge Config is connected to the project.
# No manual value is needed in production. For local dev, copy the read
# connection string from the Vercel dashboard.
EDGE_CONFIG=

# ── Edge Config writes (admin "Save to live" only) ──

# Vercel Access Token, scoped to this project. Required only for writes.
# Generate in Vercel account settings → Tokens.
VERCEL_ACCESS_TOKEN=

# Required only if the project is owned by a team. Omit for personal accounts.
VERCEL_TEAM_ID=

# The Vercel project id (project settings). Used by the Vercel REST API.
VERCEL_PROJECT_ID=
