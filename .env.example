# ── Admin authentication (server-only — never exposed to the client) ──

# Strong admin passphrase. Use at least 20 characters.
# This is the real defence against brute force; choose something long.
ADMIN_PASSWORD=

# Random string used to HMAC-sign admin session cookies.
# Generate with: openssl rand -base64 32
ADMIN_SESSION_SECRET=

# ── Vercel Edge Config (tool visibility storage) ──

# Connection string for the Edge Config store.
# Auto-injected by Vercel when an Edge Config is connected to the project.
# No manual value is needed in production. For local dev, copy the read
# connection string from the Vercel dashboard.
EDGE_CONFIG=

# ── Edge Config writes (admin "Save to live" only) ──

# Vercel Access Token, scoped to this project. Required only for writes.
# Generate in Vercel account settings → Tokens.
VERCEL_ACCESS_TOKEN=

# Required only if the project is owned by a team. Omit for personal accounts.
VERCEL_TEAM_ID=

# The Vercel project id (project settings). Used by the Vercel REST API.
VERCEL_PROJECT_ID=
